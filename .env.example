# PostgreSQL
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_DB=itocook_db

# Directus
DIRECTUS_KEY=CHANGE_ME_32_CHAR_RANDOM_HEX
DIRECTUS_SECRET=CHANGE_ME_32_CHAR_RANDOM_HEX
DIRECTUS_ADMIN_EMAIL=admin@yourcompany.com
DIRECTUS_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Frontend
NUXT_PUBLIC_DIRECTUS_URL=http://localhost:8055

# Nuxt server-side (for signup proxy)
NUXT_DIRECTUS_URL=http://directus:8055
NUXT_DIRECTUS_ADMIN_EMAIL=admin@yourcompany.com
NUXT_DIRECTUS_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD